{
  "builds": [
    {
      "src": "Backend-server.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend-src-*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Backend-server.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
